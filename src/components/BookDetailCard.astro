---
const { title, image, summary, marketplaceLink } = Astro.props;
---

<!-- Left column: Cover + Arrow -->
<div class="book-cover-wrapper col-12 col-md-5 text-center mb-4">
    <img
        src={image}
        alt={title}
        class="book-detail-img"
    />
    <a
        href="/ouvrages"
        class="back-arrow"
        aria-label="Retour aux ouvrages"
        tabindex="0"
        > &lt;
    </a>
</div>

<!-- Right column: Title + Divider + Summary + Button -->
<div class="col-12 col-md-7 text-center">
    <h2 class="book-detail-title mb-2">{title}</h2>
    <hr class="section-divider section-divider-left" />
    <p class="book-detail-summary mb-5">{summary}</p>
    {marketplaceLink && (
        <a
        href={marketplaceLink}
        class="btn-generic"
        target="_blank"
        rel="noopener noreferrer"
        >Acheter sur Amazon
        </a> 
    )} 
</div>